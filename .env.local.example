# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google AI Studio (Gemini Live API, server-side)
GOOGLE_AI_STUDIO_API_KEY=

# OpenRouter (evaluator via google/gemini-3.1-pro-preview)
OPENROUTER_API_KEY=

# Modelnamen
MODEL_LIVE=gemini-3.1-flash-live
MODEL_EVALUATOR=google/gemini-3.1-pro-preview

# n8n result webhook
N8N_RESULT_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# Cron auth (gebruikt door /api/webhook-retry voor handmatige triggers; Vercel Cron stuurt vanzelf de x-vercel-cron header)
CRON_SECRET=

# Testaccounts
TEST_ACCOUNT_PASSWORD=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
